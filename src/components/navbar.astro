---
// src/components/Navbar.astro
const { currentPath } = Astro.props;
---

<nav class="top-nav">
  <div class="nav-links">
    <a href="/" class={currentPath === "" ? "active" : ""}>首頁 / INDEX</a>
    <a href="/about" class={currentPath === "about" ? "active" : ""}>關於我 / ABOUT</a>
    <a href="/blog" class={currentPath === "blog" ? "active" : ""}>生活隨筆</a>
    <a href="/notes" class={currentPath === "notes" ? "active" : ""}>學習筆記</a>
    <a href="/research" class={currentPath === "research" ? "active" : ""}>讀讀文獻</a>
    <a href="/reading" class={currentPath === "reading" ? "active" : ""}>看看書籍</a>
    <a href="/music" class={currentPath === "music" ? "active" : ""}>聽聽音樂</a>
    <a href="/projects" class={currentPath === "projects" ? "active" : ""}>作品集</a>
  </div>

  <div class="nav-right">
    {currentPath === "about" && (
      <button id="lang-toggle" class="lang-toggle-btn">
        <span class="lang-option active" data-lang="zh">中文</span>
        <span class="lang-divider">/</span>
        <span class="lang-option" data-lang="en">EN</span>
      </button>
    )}
    <button id="search-btn" class="search-btn" title="搜尋 (/)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>
    <button id="theme-toggle" class="theme-btn" title="深色模式" aria-label="切換深色模式">
      <!-- 月亮：亮色模式下顯示 -->
      <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <!-- 太陽：深色模式下顯示 -->
      <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
    </button>
    <div class="current-time">
      <span id="live-time"></span>
    </div>
    <!-- 漢堡按鈕（僅手機顯示）-->
    <button class="burger-btn" id="burger-btn" aria-label="選單" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- 手機版展開選單 -->
<nav class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <a href="/" class={currentPath === "" ? "active" : ""}>首頁 / INDEX</a>
  <a href="/about" class={currentPath === "about" ? "active" : ""}>關於我 / ABOUT</a>
  <a href="/blog" class={currentPath === "blog" ? "active" : ""}>生活隨筆</a>
  <a href="/notes" class={currentPath === "notes" ? "active" : ""}>學習筆記</a>
  <a href="/research" class={currentPath === "research" ? "active" : ""}>讀讀文獻</a>
  <a href="/reading" class={currentPath === "reading" ? "active" : ""}>看看書籍</a>
  <a href="/music" class={currentPath === "music" ? "active" : ""}>聽聽音樂</a>
  <a href="/projects" class={currentPath === "projects" ? "active" : ""}>作品集</a>
</nav>

<script is:inline>
  function initBurger() {
    var btn  = document.getElementById('burger-btn');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    function closeMenu() {
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
      btn.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }
    function openMenu() {
      menu.classList.add('open');
      menu.setAttribute('aria-hidden', 'false');
      btn.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      menu.classList.contains('open') ? closeMenu() : openMenu();
    });

    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });

    // 點選單外部關閉（只綁一次）
    if (!window._burgerDocListenerSet) {
      window._burgerDocListenerSet = true;
      document.addEventListener('click', function (e) {
        var m = document.getElementById('mobile-menu');
        var b = document.getElementById('burger-btn');
        if (m && m.classList.contains('open') && b && !b.contains(e.target) && !m.contains(e.target)) {
          m.classList.remove('open');
          m.setAttribute('aria-hidden', 'true');
          b.classList.remove('open');
          b.setAttribute('aria-expanded', 'false');
        }
      });
    }
  }

  function initThemeToggle() {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  }

  document.addEventListener('astro:page-load', initBurger);
  document.addEventListener('astro:page-load', initThemeToggle);
  // 頁面切換時關閉選單
  document.addEventListener('astro:before-preparation', function () {
    var menu = document.getElementById('mobile-menu');
    var btn  = document.getElementById('burger-btn');
    if (menu) { menu.classList.remove('open'); menu.setAttribute('aria-hidden', 'true'); }
    if (btn)  { btn.classList.remove('open');  btn.setAttribute('aria-expanded', 'false'); }
  });
</script>

<style>
  .top-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(139, 69, 19, 0.2);
    padding: 0.8rem 0;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--muted);
    transition: color 0.3s;
    font-size: 0.85rem;
    letter-spacing: 1px;
    font-family: "Noto Serif TC", serif;
    position: relative;
    padding-bottom: 2px;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--ink);
    font-weight: 700;
  }
  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .current-time {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.5px;
  }

  .lang-toggle-btn {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0;
    transition: 0.3s;
  }
  .lang-toggle-btn:hover .lang-option { color: var(--accent); }
  .lang-option { color: var(--muted); transition: 0.3s; font-weight: 400; letter-spacing: 1px; }
  .lang-option.active { color: var(--ink); font-weight: 700; }
  .lang-divider { color: var(--border); font-size: 0.7rem; }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--muted);
    padding: 0.2rem;
    transition: color 0.3s;
    line-height: 1;
  }
  .search-btn:hover { color: var(--accent); }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--muted);
    padding: 0.2rem;
    transition: color 0.3s;
    line-height: 1;
  }
  .theme-btn:hover { color: var(--accent); }

  /* 亮色：顯示月亮；深色：顯示太陽 */
  .icon-sun { display: none; }
  :global([data-theme="dark"]) .icon-moon { display: none; }
  :global([data-theme="dark"]) .icon-sun  { display: block; }

  /* ── 漢堡按鈕（桌面隱藏）── */
  .burger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
    width: 28px;
    height: 28px;
  }
  .burger-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  .burger-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── 手機展開選單（桌面隱藏）── */
  .mobile-menu {
    display: none;
  }

  /* ── 手機版（≤768px）── */
  @media (max-width: 768px) {
    /* 隱藏桌面導覽列和時鐘 */
    .nav-links  { display: none; }
    .current-time { display: none; }

    /* 顯示漢堡按鈕 */
    .burger-btn { display: flex; }

    /* 展開選單：固定在 navbar 下方 */
    .mobile-menu {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: var(--nav-h, 56px);
      left: 0;
      right: 0;
      background: rgba(253, 250, 246, 0.97);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 2px solid var(--border);
      padding: 0.4rem 1.5rem 0.8rem;
      /* 預設：收起（向上滑出）*/
      transform: translateY(-110%);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
      z-index: 98;
    }
    :global([data-theme="dark"]) .mobile-menu {
      background: rgba(28, 24, 20, 0.97);
    }
    .mobile-menu.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    .mobile-menu a {
      font-family: "Noto Serif TC", serif;
      font-size: 0.92rem;
      color: var(--muted);
      text-decoration: none;
      padding: 0.75rem 0;
      border-bottom: 1px dashed var(--border);
      transition: color 0.2s, padding-left 0.2s;
      letter-spacing: 0.5px;
      display: block;
    }
    .mobile-menu a:last-child { border-bottom: none; }
    .mobile-menu a.active { color: var(--ink); font-weight: 700; }
    .mobile-menu a:hover  { color: var(--accent); padding-left: 0.5rem; }
  }
</style>
