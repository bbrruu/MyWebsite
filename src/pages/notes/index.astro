---
// ── 頁面介紹（可直接修改這段文字）──
const pageDesc = "這裡會有我學習新知後所做的筆記。";

import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allNotes = (await getCollection("notes")).sort(
  (a: CollectionEntry<"notes">, b: CollectionEntry<"notes">) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = ["語言", "歷史文化", "NLP", "天文"];

const groupedNotes: Record<string, CollectionEntry<"notes">[]> = allNotes.reduce(
  (acc: Record<string, CollectionEntry<"notes">[]>, note) => {
    const date = new Date(note.data.pubDate);
    const year = date.getFullYear();
    const month = date.getMonth() + 1;
    const key = `${year}年 ${month}月`;
    if (!acc[key]) acc[key] = [];
    acc[key].push(note);
    return acc;
  },
  {}
);

const months = Object.keys(groupedNotes);
---

<Layout title="學習筆記 | Field Notes - Bruce">
  <div class="paper-texture"></div>

  <main class="notes-archive">
    <header class="archive-header">
      <div class="header-row">
        <h1>學習筆記 <small>FIELD NOTES</small></h1>
        <p class="page-desc">{pageDesc}</p>
        <div class="archive-filter">
          <label for="cat-select" class="filter-label">FILTER</label>
          <div class="select-wrapper">
            <select id="cat-select" class="filter-select">
              <option value="all">全部 ALL</option>
              {categories.map((cat) => (
                <option value={cat}>{cat}</option>
              ))}
            </select>
            <span class="select-arrow">↓</span>
          </div>
        </div>
      </div>
      <div class="header-line"></div>
    </header>

    <div class="archive-content" id="master-list">
      {months.map((month) => (
        <section class="month-section" data-month={month}>
          <div class="month-header">
            <h2 class="month-title">{month}</h2>
            <div class="note-count">{groupedNotes[month].length} ENTRIES</div>
          </div>

          <div class="note-list">
            {groupedNotes[month].map((note) => (
              <div class="note-wrapper" data-cat={note.data.category}>
                <a href={`/notes/${note.id}`} class="note-entry">
                  <div class="entry-left">
                    <div class="title-swap-container">
                      <div class="title-default">{note.data.title}</div>
                      <div class="title-hover">
                        <span class="cat-tag">#{note.data.category}</span>
                        {note.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="sub-tag">{tag}</span>
                        ))}
                      </div>
                    </div>
                    {note.data.description && (
                      <p class="entry-desc">{note.data.description}</p>
                    )}
                  </div>
                  <div class="entry-arrow">
                    <span class="view-text">READ</span>
                    <span class="arrow">→</span>
                  </div>
                </a>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>
</Layout>

<script is:inline>
  function notesSetup() {
    var select = document.getElementById('cat-select');
    var sections = document.querySelectorAll('.month-section');
    if (!select) return;

    select.addEventListener('change', function() {
      var val = select.value;
      var wrappers = document.querySelectorAll('.note-wrapper');

      wrappers.forEach(function(w) {
        var wCat = w.getAttribute('data-cat');
        w.classList.toggle('is-hidden', val !== 'all' && wCat !== val);
      });

      setTimeout(function() {
        sections.forEach(function(sec) {
          var visible = sec.querySelectorAll('.note-wrapper:not(.is-hidden)');
          sec.classList.toggle('month-hidden', visible.length === 0);
        });
      }, 100);
    });
  }
  document.addEventListener('astro:page-load', notesSetup);
</script>

<style>
  .notes-archive {
    max-width: 1400px;
    margin: 2rem auto;
    font-family: "Noto Serif TC", serif;
  }

  .header-row { display: flex; align-items: flex-end; gap: 2.5rem; }

  .archive-header h1 {
    font-size: 1.6rem; margin: 0; font-weight: 700; letter-spacing: -1.5px;
  }
  .archive-header h1 small {
    font-size: 0.75rem; font-family: sans-serif; letter-spacing: 4px;
    color: var(--muted); font-weight: 400; margin-left: 0.6rem;
  }

  .page-desc {
    flex: 1; font-size: 0.82rem; color: var(--muted); line-height: 1.8;
    margin: 0 0 0.15rem 0; font-style: italic;
    padding-left: 2rem; border-left: 1px solid var(--border);
  }

  .header-line { width: 100%; height: 1px; background: var(--border); margin: 1.2rem 0 1.5rem; position: relative; }
  .header-line::after { content: ''; position: absolute; left: 0; top: -1px; width: 80px; height: 3px; background: var(--accent); }

  .archive-filter { display: flex; align-items: center; gap: 0.6rem; padding-bottom: 0.15rem; flex-shrink: 0; }
  .filter-label { font-size: 0.6rem; font-family: sans-serif; letter-spacing: 2px; color: var(--muted); font-weight: 700; text-transform: uppercase; white-space: nowrap; }
  .select-wrapper { position: relative; display: inline-flex; align-items: center; }
  .filter-select {
    appearance: none; -webkit-appearance: none;
    background: transparent; border: 1px solid var(--border); border-radius: 3px;
    padding: 0.3rem 1.8rem 0.3rem 0.7rem;
    font-size: 0.78rem; font-family: "Noto Serif TC", serif; color: var(--ink);
    cursor: pointer; transition: border-color 0.3s, color 0.3s; min-width: 160px;
  }
  .filter-select:focus { outline: none; border-color: var(--accent); }
  .filter-select:hover { border-color: var(--accent); color: var(--accent); }
  .select-arrow { position: absolute; right: 0.5rem; font-size: 0.6rem; color: var(--muted); pointer-events: none; transition: color 0.3s; }
  .select-wrapper:hover .select-arrow { color: var(--accent); }

  .month-section { margin-bottom: 3.5rem; transition: opacity 0.4s, transform 0.4s; }
  .month-section.month-hidden { opacity: 0; height: 0; margin-bottom: 0; overflow: hidden; pointer-events: none; }

  .month-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    padding-bottom: 0.8rem; border-bottom: 2px solid var(--ink); margin-bottom: 0.8rem;
  }
  .month-title { font-size: 1.4rem; margin: 0; color: var(--ink); font-weight: 700; }
  .note-count { font-size: 0.72rem; color: var(--accent); font-weight: 700; font-family: sans-serif; letter-spacing: 1px; }

  .note-wrapper { transition: opacity 0.4s, max-height 0.4s; max-height: 200px; overflow: visible; }
  .note-wrapper.is-hidden { overflow: hidden; }
  .note-wrapper.is-hidden { opacity: 0; max-height: 0; pointer-events: none; }

  .note-entry {
    display: flex; align-items: center; justify-content: space-between;
    text-decoration: none; color: inherit;
    padding: 0.9rem 0; border-bottom: 1px dashed var(--border);
    transition: 0.4s;
  }
  .note-entry:hover { background: rgba(139,69,19,0.02); padding-left: 1.5rem; }

  .entry-left { flex: 1; overflow: hidden; }

  .title-swap-container {
    position: relative; height: 1.5rem; overflow: hidden;
    display: flex; align-items: center;
  }
  .title-default, .title-hover {
    font-size: 1rem; font-weight: 700; transition: all 0.5s cubic-bezier(0.23,1,0.32,1);
    white-space: nowrap; line-height: 1.5rem;
  }
  .title-hover {
    position: absolute; top: 0; left: 0; opacity: 0;
    transform: translateY(15px); color: var(--accent);
    display: flex; align-items: center; gap: 0.8rem;
  }
  .note-entry:hover .title-default { opacity: 0; transform: translateY(-15px); }
  .note-entry:hover .title-hover { opacity: 1; transform: translateY(0); }

  .cat-tag {
    font-size: 0.78rem; font-weight: 700; color: var(--accent);
    background: rgba(139,69,19,0.1); padding: 2px 8px;
    border-radius: 4px; font-family: sans-serif;
  }
  .sub-tag { font-size: 0.72rem; color: var(--muted); font-weight: 400; font-family: sans-serif; }

  .entry-desc {
    font-size: 0.78rem; color: var(--muted); margin: 0.2rem 0 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    transition: opacity 0.4s;
  }
  .note-entry:hover .entry-desc { opacity: 0; }

  .entry-arrow {
    display: flex; align-items: center; gap: 1rem;
    font-size: 0.75rem; letter-spacing: 2px; color: var(--muted);
    opacity: 0.4; transition: 0.4s; font-family: sans-serif; flex-shrink: 0;
  }
  .note-entry:hover .entry-arrow { opacity: 1; color: var(--accent); transform: translateX(5px); }
  .view-text { font-weight: 700; }

  @media (max-width: 768px) {
    .entry-arrow .view-text { display: none; }
    .archive-header h1 { font-size: 1.4rem; }
    .header-row { flex-direction: column; gap: 0.8rem; }
    .page-desc { border-left: none; padding-left: 0; }
  }
</style>
