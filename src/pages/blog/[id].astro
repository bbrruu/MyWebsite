---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return posts.map((post, idx) => ({
    params: { id: post.id },
    props: {
      post,
      prev: idx < posts.length - 1 ? posts[idx + 1] : null,
      next: idx > 0 ? posts[idx - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
const { category, tags, quote } = post.data;
---

<Layout title={`${post.data.title} | Bruce 的手帳`}>

  <div class="jnl-outer">
    <div class="book-spread">

      <!-- ── LEFT PAGE: Metadata ── -->
      <div class="book-page left-page">
        <!-- Small botanical deco -->
        <svg class="meta-botanical" viewBox="0 0 120 180" xmlns="http://www.w3.org/2000/svg">
          <path class="mb-fill" d="M60 165 C52 145 28 122 22 96 C16 72 28 52 46 44 C64 36 82 48 88 72 C94 92 86 122 70 142 Z"/>
          <path class="mb-stroke" d="M60 165 C52 145 28 122 22 96 C16 72 28 52 46 44 C64 36 82 48 88 72 C94 92 86 122 70 142 Z"/>
          <path class="mb-hole" d="M48 88 C46 80 53 72 60 74 C67 76 68 85 63 91 Z"/>
          <line class="mb-vein" x1="60" y1="165" x2="40" y2="105"/>
          <line class="mb-vein" x1="60" y1="165" x2="80" y2="118"/>
          <circle class="mb-berry" cx="94" cy="46" r="3.5"/>
          <circle class="mb-berry" cx="103" cy="40" r="2.5"/>
          <circle class="mb-berry-sm" cx="99" cy="32" r="2"/>
          <path class="mb-sprig" d="M18 42 C10 28 14 16 22 18"/>
          <path class="mb-sprig" d="M18 42 C8 38 6 26 12 20"/>
          <path class="mb-sprig" d="M18 42 C10 40 6 32 8 24"/>
          <line class="mb-sprig" x1="18" y1="42" x2="16" y2="14"/>
        </svg>

        <!-- Back nav -->
        <a href="/blog" class="back-link">
          <span>←</span>
          <span>返回索引</span>
        </a>

        <!-- 裝飾章印（絕對定位於左下角）-->
        {category === '旅行' && (
          <svg class="cat-stamp" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="36" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="40" cy="40" r="31" fill="none" stroke="currentColor" stroke-width="0.7"/>
            <path d="M40 16 L43 32 L57 34 L43 36 L40 52 L37 36 L23 34 L37 32 Z"
              fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            <circle cx="40" cy="34" r="2.5" fill="currentColor"/>
            <text x="40" y="63" text-anchor="middle" font-family="sans-serif" font-size="5.5" letter-spacing="2" font-weight="700" fill="currentColor">TRAVEL</text>
          </svg>
        )}
        {category === '日常' && (
          <svg class="cat-stamp" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="36" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="40" cy="40" r="31" fill="none" stroke="currentColor" stroke-width="0.7"/>
            <circle cx="40" cy="33" r="7.5" fill="none" stroke="currentColor" stroke-width="1.4"/>
            <line x1="40" y1="18" x2="40" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="40" y1="44" x2="40" y2="48" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="25" y1="33" x2="29" y2="33" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="51" y1="33" x2="55" y2="33" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="29.4" y1="22.4" x2="32.2" y2="25.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="47.8" y1="40.8" x2="50.6" y2="43.6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="50.6" y1="22.4" x2="47.8" y2="25.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="32.2" y1="40.8" x2="29.4" y2="43.6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <text x="40" y="63" text-anchor="middle" font-family="sans-serif" font-size="5.5" letter-spacing="2" font-weight="700" fill="currentColor">DAILY</text>
          </svg>
        )}
        {category === '省思' && (
          <svg class="cat-stamp" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
            <circle cx="40" cy="40" r="36" fill="none" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="40" cy="40" r="31" fill="none" stroke="currentColor" stroke-width="0.7"/>
            <path d="M24 21 L40 24 L40 51 L24 48 Z" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            <path d="M40 24 L56 21 L56 48 L40 51 Z" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            <line x1="28" y1="31" x2="38" y2="32.5" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
            <line x1="28" y1="36" x2="38" y2="37.5" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
            <line x1="28" y1="41" x2="38" y2="42.5" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
            <line x1="42" y1="32.5" x2="52" y2="31" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
            <line x1="42" y1="37.5" x2="52" y2="36" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
            <line x1="42" y1="42.5" x2="52" y2="41" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
            <text x="40" y="63" text-anchor="middle" font-family="sans-serif" font-size="5.5" letter-spacing="2" font-weight="700" fill="currentColor">REFLECT</text>
          </svg>
        )}

        <!-- Meta block -->
        <div class="meta-block">
          <h1 class="meta-title">{post.data.title}</h1>
          {quote && <p class="meta-quote">「{quote}」</p>}
          <div class="meta-rule"></div>
          <dl class="meta-dl">
            <dt>DATE</dt>
            <dd>{post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })}</dd>
            <dt>MOOD</dt>
            <dd>{post.data.mood || '還行'}</dd>
            <dt>LOCATION</dt>
            <dd>{post.data.location || 'Taipei'}</dd>
            {tags.length > 0 && (
              <>
                <dt>TAGS</dt>
                <dd class="tag-list">{tags.map(t => <span class="tag">{t}</span>)}</dd>
              </>
            )}
          </dl>
        </div>

        <!-- Post navigation at bottom -->
        <div class="post-nav">
          {prev && (
            <a href={`/blog/${prev.id}`} class="post-nav-link">
              <span class="nav-dir">← 上一篇</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          )}
          {next && (
            <a href={`/blog/${next.id}`} class="post-nav-link post-nav-right">
              <span class="nav-dir">下一篇 →</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          )}
        </div>

        <div class="page-num">INDEX</div>
      </div>

      <!-- ── SPINE ── -->
      <div class="book-spine">
        <span class="spine-label">LIFE JOURNAL · 生活隨筆</span>
      </div>

      <!-- ── RIGHT PAGE: Content (paginated) ── -->
      <div class="book-page right-page" id="content-page">

        <!-- Hidden source — Astro renders Content here -->
        <div id="content-source" aria-hidden="true">
          <Content />
        </div>

        <!-- Flip wrapper: has 3D perspective -->
        <div class="flip-outer" id="flip-outer">
          <div class="flip-inner" id="flip-inner">
            <!-- Displayed content (filled by JS) -->
            <div class="content-display" id="content-display"></div>
          </div>
        </div>

        <!-- Controls -->
        <div class="page-controls">
          <button id="pg-prev" class="pg-btn" aria-label="上一頁" disabled>‹</button>
          <span id="pg-indicator" class="pg-indicator">— / —</span>
          <button id="pg-next" class="pg-btn" aria-label="下一頁">›</button>
        </div>
      </div>

    </div>
  </div>

</Layout>

<script>
  async function initJournal() {
    const source   = document.getElementById('content-source') as HTMLElement | null;
    const display  = document.getElementById('content-display') as HTMLElement | null;
    const flipInner= document.getElementById('flip-inner') as HTMLElement | null;
    const prevBtn  = document.getElementById('pg-prev') as HTMLButtonElement | null;
    const nextBtn  = document.getElementById('pg-next') as HTMLButtonElement | null;
    const indicator= document.getElementById('pg-indicator') as HTMLElement | null;
    if (!source || !display || !flipInner) return;

    const d = display;

    // ── 1. 把 <br> 拆開成獨立行，避免單一長段落無法分頁 ──
    function expandBr(rawNodes: Element[]): Element[] {
      const result: Element[] = [];
      for (const el of rawNodes) {
        if (!el.querySelector('br')) { result.push(el); continue; }
        const tag = el.tagName.toLowerCase();
        let chunk = document.createElement(tag);
        for (const child of Array.from(el.childNodes)) {
          if (child.nodeName === 'BR') {
            if (chunk.hasChildNodes()) { result.push(chunk); chunk = document.createElement(tag); }
          } else {
            chunk.appendChild(child.cloneNode(true));
          }
        }
        if (chunk.hasChildNodes()) result.push(chunk);
      }
      return result;
    }

    const rawNodes = Array.from(source.children) as Element[];

    // ── 2. 把所有 img 預先包成 figure，樣式由 CSS 控制 ──
    function wrapImages(nodeList: Element[]): Element[] {
      return nodeList.map(el => {
        if (!el.querySelector('img')) return el;
        const cloned = el.cloneNode(true) as Element;
        Array.from(cloned.querySelectorAll('img')).forEach(img => {
          if (img.closest('figure')) return;
          const alt = (img as HTMLImageElement).alt ?? '';
          const fig = document.createElement('figure');
          const imgEl = img.cloneNode(true) as HTMLImageElement;
          fig.appendChild(imgEl);
          if (alt) {
            const cap = document.createElement('figcaption');
            cap.textContent = alt;
            fig.appendChild(cap);
          }
          img.replaceWith(fig);
        });
        return cloned;
      });
    }

    // ── 3. 把含有 figure 和文字混在一起的節點拆開，各自獨立成節點 ──
    function splitMixedNodes(nodeList: Element[]): Element[] {
      const result: Element[] = [];
      for (const el of nodeList) {
        if (!el.querySelector('figure')) { result.push(el); continue; }
        const tag = el.tagName.toLowerCase();
        let textBuf = document.createElement(tag);
        for (const child of Array.from(el.childNodes)) {
          if (child.nodeName === 'FIGURE') {
            if (textBuf.hasChildNodes()) { result.push(textBuf); textBuf = document.createElement(tag); }
            result.push(child.cloneNode(true) as Element);
          } else {
            textBuf.appendChild(child.cloneNode(true));
          }
        }
        if (textBuf.hasChildNodes()) result.push(textBuf);
      }
      return result;
    }

    const nodes = splitMixedNodes(wrapImages(expandBr(rawNodes)));
    if (nodes.length === 0) return;

    // ── 3. 可用高度 ──
    const availH = () => {
      const page = d.closest('.right-page') as HTMLElement;
      return page ? page.clientHeight - 150 : 400;
    };

    // ── 4. 依高度分頁 ──
    function buildPages(): Element[][] {
      const pages: Element[][] = [];
      let page: Element[] = [];
      let h = 0;
      const limit = availH();

      const ruler = document.createElement('div');
      ruler.className = 'content-display';
      ruler.style.cssText = `
        position: absolute; visibility: hidden; pointer-events: none;
        width: ${d.clientWidth}px;
        font-size: 1rem; line-height: 30px; font-family: "Noto Serif TC", serif;
        padding: 0; margin: 0;
      `;
      document.body.appendChild(ruler);

      for (const node of nodes) {
        const clone = node.cloneNode(true) as HTMLElement;
        clone.style.margin = '0';
        clone.style.padding = '0';
        clone.style.lineHeight = '30px';
        ruler.appendChild(clone);
        let nodeH = (ruler.lastElementChild?.getBoundingClientRect().height ?? 30);
        ruler.removeChild(clone);

        if (h + nodeH > limit && page.length > 0) {
          pages.push(page);
          page = [node];
          h = nodeH;
        } else {
          page.push(node);
          h += nodeH;
        }
      }
      if (page.length > 0) pages.push(page);

      document.body.removeChild(ruler);

      // 孤立標題修正：末尾是標題就移到下一頁開頭
      for (let i = 0; i < pages.length - 1; i++) {
        const pg = pages[i];
        const last = pg[pg.length - 1];
        if (/^H[1-6]$/.test(last.tagName)) {
          pg.pop();
          pages[i + 1].unshift(last);
          if (pg.length === 0) { pages.splice(i, 1); i--; }
        }
      }

      return pages;
    }

    let pages: Node[][] = [];
    let cur = 0;

    function renderPage(idx: number) {
      d.innerHTML = '';
      (pages[idx] || []).forEach(n => d.appendChild(n.cloneNode(true)));
    }

    function updateControls() {
      if (!prevBtn || !nextBtn || !indicator) return;
      prevBtn.disabled = cur === 0;
      nextBtn.disabled = cur >= pages.length - 1;
      indicator.textContent = `${cur + 1} / ${pages.length}`;
    }

    function flipTo(idx: number, dir: 1 | -1) {
      if (idx < 0 || idx >= pages.length) return;
      // Half-flip: exit → swap → enter
      const exitClass = dir > 0 ? 'flip-exit-left' : 'flip-exit-right';
      const enterClass = dir > 0 ? 'flip-enter-right' : 'flip-enter-left';

      flipInner!.classList.add(exitClass);
      setTimeout(() => {
        flipInner!.classList.remove(exitClass);
        cur = idx;
        renderPage(cur);
        updateControls();
        flipInner!.classList.add(enterClass);
        setTimeout(() => flipInner!.classList.remove(enterClass), 280);
      }, 240);
    }

    // ── Init ──
    // 預載所有圖片，確保量高度時尺寸正確
    const allImgs = Array.from(source.querySelectorAll('img'));
    if (allImgs.length > 0) {
      await Promise.all(allImgs.map(img => {
        if ((img as HTMLImageElement).complete) return Promise.resolve();
        const i = new Image();
        return new Promise<void>(resolve => {
          i.onload = () => resolve();
          i.onerror = () => resolve();
          i.src = (img as HTMLImageElement).src;
        });
      }));
    }
    // 等 layout 穩定後再分頁
    await new Promise<void>(r => requestAnimationFrame(() => r()));
    pages = buildPages();
    cur = 0;
    renderPage(0);
    updateControls();

    prevBtn?.addEventListener('click', () => { if (cur > 0) flipTo(cur - 1, -1); });
    nextBtn?.addEventListener('click', () => { if (cur < pages.length - 1) flipTo(cur + 1, 1); });

    // Keyboard support
    const onKey = (e: KeyboardEvent) => {
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.key === 'ArrowRight' && cur < pages.length - 1) flipTo(cur + 1, 1);
      if (e.key === 'ArrowLeft'  && cur > 0)               flipTo(cur - 1, -1);
    };
    document.addEventListener('keydown', onKey);

    // Rebuild on resize
    let resizeTimer: ReturnType<typeof setTimeout>;
    const onResize = () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        pages = buildPages();
        cur = Math.min(cur, pages.length - 1);
        renderPage(cur);
        updateControls();
      }, 200);
    };
    window.addEventListener('resize', onResize);
  }

  document.addEventListener('astro:page-load', initJournal);
</script>

<style>
  /* ── Outer wrapper ── */
  .jnl-outer {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 120px);
    padding: 1.5rem 0;
  }

  /* ── Book spread ── */
  .book-spread {
    display: flex;
    align-items: stretch;
    width: 100%;
    max-width: 880px;
    height: 600px;
    box-shadow:
      -8px 8px 32px rgba(0,0,0,0.18),
       8px 8px 32px rgba(0,0,0,0.10);
    border-radius: 2px 6px 6px 2px;
  }

  /* ── Shared page ── */
  .book-page {
    flex: 1;
    position: relative;
    background: var(--paper);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .page-lines {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent, transparent 31px,
      rgba(180,160,130,0.12) 31px,
      rgba(180,160,130,0.12) 32px
    );
    background-position: 0 48px;
    pointer-events: none;
    z-index: 0;
  }
  .page-num {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    font-family: sans-serif;
    color: var(--muted);
    letter-spacing: 1px;
    z-index: 2;
  }

  /* ── LEFT PAGE ── */
  .left-page {
    border-radius: 2px 0 0 2px;
    padding: 24px 24px 40px;
  }

  .meta-botanical {
    position: absolute;
    top: 0;
    right: 0;
    width: 55%;
    height: auto;
    opacity: 0.75;
    z-index: 0;
  }
  .mb-fill    { fill: rgba(139,69,19,0.07); }
  .mb-stroke  { fill: none; stroke: rgba(139,69,19,0.50); stroke-width: 1.4; stroke-linecap: round; stroke-linejoin: round; }
  .mb-hole    { fill: var(--paper); stroke: rgba(139,69,19,0.50); stroke-width: 1.2; }
  .mb-vein    { fill: none; stroke: rgba(139,69,19,0.28); stroke-width: 0.9; stroke-linecap: round; }
  .mb-berry   { fill: rgba(139,69,19,0.38); stroke: rgba(139,69,19,0.55); stroke-width: 0.8; }
  .mb-berry-sm{ fill: rgba(139,69,19,0.20); }
  .mb-sprig   { fill: none; stroke: rgba(139,69,19,0.38); stroke-width: 1; stroke-linecap: round; }

  .back-link {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.6rem;
    font-family: sans-serif;
    letter-spacing: 2px;
    color: var(--muted);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.3s;
    margin-bottom: 1.2rem;
  }
  .back-link:hover { color: var(--accent); }

  .meta-block {
    position: relative;
    z-index: 2;
    flex: 1;
  }
  .cat-stamp {
    display: block;
    position: absolute;
    bottom: 155px;
    left: 20px;
    width: 116px;
    height: 116px;
    color: var(--accent);
    opacity: 0.50;
    transform: rotate(-8deg);
    z-index: 2;
  }
  .meta-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.6rem 0;
    line-height: 1.4;
    color: var(--ink);
    letter-spacing: -0.3px;
  }
  .meta-quote {
    font-size: 0.74rem;
    font-style: italic;
    color: var(--muted);
    margin: 0.3rem 0 0.5rem;
    padding-left: 8px;
    border-left: 2px solid rgba(139,69,19,0.25);
    line-height: 1.5;
  }
  .meta-rule {
    width: 32px;
    height: 2px;
    background: var(--accent);
    margin-bottom: 1rem;
  }
  .meta-dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.3rem 0.8rem;
    margin: 0;
  }
  .meta-dl dt {
    font-size: 0.52rem;
    font-family: sans-serif;
    letter-spacing: 1.5px;
    color: var(--muted);
    font-weight: 700;
    text-transform: uppercase;
    align-self: baseline;
    padding: 4px 0;
    border-bottom: 1px solid rgba(180, 160, 130, 0.30);
  }
  .meta-dl dd {
    font-size: 0.78rem;
    color: var(--ink);
    font-family: sans-serif;
    margin: 0;
    align-self: baseline;
    padding: 4px 0;
    border-bottom: 1px solid rgba(180, 160, 130, 0.30);
  }

  /* Post prev/next nav at bottom of left page */
  .post-nav {
    position: absolute;
    bottom: 36px;
    left: 24px;
    right: 24px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 1px;
    text-decoration: none;
    color: var(--muted);
    transition: color 0.25s;
  }
  .post-nav-link:hover { color: var(--accent); }
  .post-nav-right { align-items: flex-end; }
  .nav-dir {
    font-size: 0.52rem;
    font-family: sans-serif;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .nav-title {
    font-size: 0.75rem;
    font-weight: 700;
    font-family: "Noto Serif TC", serif;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .post-nav-link:hover .nav-title { color: var(--accent); }

  /* ── SPINE ── */
  .book-spine {
    width: 38px;
    flex-shrink: 0;
    background: linear-gradient(to right,
      rgba(100,60,20,0.20) 0%,
      rgba(139,69,19,0.28) 30%,
      rgba(100,60,20,0.22) 60%,
      rgba(80,45,12,0.32) 100%
    );
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 3;
    box-shadow:
      inset -3px 0 8px rgba(0,0,0,0.12),
      inset  3px 0 8px rgba(0,0,0,0.08);
  }
  .spine-label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-size: 0.48rem;
    font-family: sans-serif;
    letter-spacing: 2px;
    color: rgba(139,69,19,0.8);
    font-weight: 700;
    white-space: nowrap;
  }

  /* ── RIGHT PAGE ── */
  .right-page {
