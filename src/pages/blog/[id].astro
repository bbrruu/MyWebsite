---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return posts.map((post, idx) => ({
    params: { id: post.id },
    props: {
      post,
      prev: idx < posts.length - 1 ? posts[idx + 1] : null,
      next: idx > 0 ? posts[idx - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | 生活隨筆`}>
  <div class="paper-texture"></div>

  <article class="content-article">
    <nav class="inner-nav">
      <a href="/blog" class="back-link">
        <span class="arrow">←</span>
        <span class="text">INDEX / LIFE JOURNAL</span>
      </a>
    </nav>

    <header class="post-header">
      <div class="post-meta-card">
        <div class="meta-grid">
          <span class="meta-label">CATEGORY</span>
          <span class="meta-value">{post.data.category}</span>

          <span class="meta-label">MOOD</span>
          <span class="meta-value author-name">{post.data.mood || '還行'}</span>

          <span class="meta-label">POSTED</span>
          <span class="meta-value date">{post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })}</span>
        </div>
      </div>

      <div class="title-wrapper">
        <h1 class="post-title">{post.data.title}</h1>
      </div>
      <div class="dynamic-accent-line"></div>
    </header>

    <section class="post-content">
      <Content />
    </section>

    <footer class="post-footer">
      <div class="footer-info">
        <span>📍 {post.data.location || 'Taipei'}</span>
        <span class="dot">•</span>
        <span>Bruce's Life Journal</span>
      </div>
    </footer>

    {(prev || next) && (
      <nav class="post-pagination">
        <div class="pagination-inner">
          {prev ? (
            <a href={`/blog/${prev.id}`} class="pag-link pag-prev">
              <span class="pag-dir">← 上一篇</span>
              <span class="pag-title">{prev.data.title}</span>
            </a>
          ) : <div />}
          {next ? (
            <a href={`/blog/${next.id}`} class="pag-link pag-next">
              <span class="pag-dir">下一篇 →</span>
              <span class="pag-title">{next.data.title}</span>
            </a>
          ) : <div />}
        </div>
      </nav>
    )}
  </article>
</Layout>

<style>
  .content-article { width: 100%; padding: 0; font-family: "Noto Serif TC", serif; color: var(--ink); }
  .inner-nav { margin-bottom: 1.5rem; }
  .back-link { display: inline-flex; align-items: center; text-decoration: none; color: var(--muted); font-size: 0.7rem; letter-spacing: 2px; font-family: sans-serif; }
  .back-link:hover { color: var(--accent); }
  .back-link .arrow { margin-right: 8px; transition: 0.4s ease; }

  .post-header { position: relative; margin-top: 0; }
  .title-wrapper { padding-right: 380px; }
  .post-title { font-size: 2rem; margin: 0; font-weight: 700; letter-spacing: -1.5px; line-height: 1.4; color: var(--ink); padding-bottom: 1rem; }
  .dynamic-accent-line { width: 100%; height: 4px; background-color: var(--accent); border-radius: 2px; }

  .post-meta-card { position: absolute; bottom: 1rem; right: 0; background: rgba(139, 69, 19, 0.03); border: 1px solid var(--border); padding: 0.6rem 0.9rem; border-radius: 4px; width: max-content; min-width: 200px; max-width: 360px; }
  .meta-grid { display: grid; grid-template-columns: auto max-content; align-items: baseline; column-gap: 0.7rem; row-gap: 0.35rem; }
  .meta-label { font-size: 0.55rem; font-family: sans-serif; color: var(--muted); letter-spacing: 1.5px; font-weight: 700; text-transform: uppercase; }
  .meta-value { font-size: 0.72rem; font-family: sans-serif; color: var(--muted); font-weight: 600; }
  .author-name { color: var(--accent); font-size: 0.78rem; font-weight: 700; }

  .post-content { width: 100%; line-height: 2.2; font-size: 1.15rem; text-align: justify; margin-top: 1.8rem; }

  /* ── 日記自訂樣式（在 .md 裡用 HTML 標籤調用） ── */

  /* 螢光筆：<mark>文字</mark> */
  .post-content mark {
    background: #fff9c4;
    padding: 0 3px;
    border-radius: 2px;
    font-style: normal;
  }

  /* 強調紅字：<span class="hl-red">文字</span> */
  .post-content .hl-red {
    color: #c0392b;
    font-weight: 700;
  }

  /* 強調藍字：<span class="hl-blue">文字</span> */
  .post-content .hl-blue {
    color: #2471a3;
    font-weight: 700;
  }

  /* 旁白補充框：<div class="note">內容</div> */
  .post-content .note {
    border-left: 3px solid var(--accent);
    padding: 0.5rem 1rem;
    margin: 1.2rem 0;
    background: rgba(139,69,19,0.04);
    font-size: 0.95rem;
    color: var(--muted);
    font-style: italic;
  }

  /* 小字說明：<span class="caption">補充說明</span> */
  .post-content .caption {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: sans-serif;
    letter-spacing: 0.5px;
  }
  .post-footer { margin-top: 10rem; padding-top: 2rem; border-top: 1px dashed var(--border); }
  .footer-info { display: flex; align-items: center; gap: 1rem; font-size: 0.75rem; color: var(--muted); font-family: sans-serif; }

  @media (max-width: 768px) {
    .post-header { padding-right: 0; }
    .post-meta-card { position: static; width: 100%; margin-top: 1rem; }
  }

  .post-pagination { margin-top: 3rem; padding-top: 2rem; border-top: 1px dashed var(--border); }
  .pagination-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .pag-link { display: flex; flex-direction: column; gap: 0.4rem; text-decoration: none; color: var(--muted); transition: color 0.3s; padding: 0.8rem 0; }
  .pag-link:hover { color: var(--accent); }
  .pag-dir { font-size: 0.6rem; font-family: sans-serif; letter-spacing: 2px; text-transform: uppercase; }
  .pag-title { font-size: 0.9rem; font-weight: 700; font-family: "Noto Serif TC", serif; color: var(--ink); line-height: 1.4; }
  .pag-link:hover .pag-title { color: var(--accent); }
  .pag-next { text-align: right; }

  @media (max-width: 768px) {
    .pagination-inner { grid-template-columns: 1fr; }
    .pag-next { text-align: left; }
  }
</style>