---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

// 1. 抓取文章並排序
const allPosts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 2. 定義分類標籤
const categories = ["旅行", "日常", "省思"];

// 3. 處理月份分組邏輯
const groupedPosts: Record<string, CollectionEntry<"blog">[]> = allPosts.reduce((acc: Record<string, CollectionEntry<"blog">[]>, post) => {
    const date = new Date(post.data.pubDate);
    const year = date.getFullYear();
    const month = date.getMonth() + 1;
    const monthKey = `${year}年 ${month}月`;
    if (!acc[monthKey]) acc[monthKey] = [];
    acc[monthKey].push(post);
    return acc;
}, {});

const months = Object.keys(groupedPosts);
---

<Layout title="生活隨筆 | 拾光目錄 - Bruce">
    <div class="paper-texture"></div>

    <main class="blog-archive">
        <header class="archive-header">
            <h1>生活隨筆 <small>COLLECTED MOMENTS</small></h1>
            <div class="header-line"></div>

            <div class="category-filter">
                <label for="category-select" class="filter-label">FILTER BY CATEGORY</label>
                <div class="select-wrapper">
                    <select id="category-select" class="category-select">
                        <option value="all">全部 ALL</option>
                        {categories.map((cat) => (
                            <option value={cat}>{cat}</option>
                        ))}
                    </select>
                    <span class="select-arrow">↓</span>
                </div>
            </div>
        </header>

        <div class="archive-content" id="master-list">
            {months.map((month) => (
                <section class="month-section" data-month={month}>
                    <div class="month-header">
                        <div class="month-name-group">
                            <span class="prefix">Daily Journal / Diary</span>
                            <h2 class="month-title">{month}</h2>
                        </div>
                        <div class="note-count">{groupedPosts[month].length} ENTRIES</div>
                    </div>

                    <div class="note-list">
                        {groupedPosts[month].map((post) => (
                            <div class="note-wrapper" data-cat={post.data.category}>
                                <a href={`/blog/${post.id}`} class="blog-entry">
                                    <div class="title-swap-container">
                                        <div class="title-default">
                                            {post.data.title}
                                        </div>
                                        <div class="title-hover">
                                            <span class="cat-tag">#{post.data.category}</span>
                                            <span class="sub-tag">📍 {post.data.location || "Taipei"}</span>
                                            <span class="sub-tag">心情：{post.data.mood || "還行"}</span>
                                        </div>
                                    </div>
                                    <div class="entry-arrow">
                                        <span class="view-text">READ ENTRY</span>
                                        <span class="arrow">→</span>
                                    </div>
                                </a>
                            </div>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </main>
</Layout>

<script>
    const setupFilters = () => {
        const select = document.getElementById("category-select") as HTMLSelectElement | null;
        const posts = document.querySelectorAll<HTMLElement>(".note-wrapper");
        const monthSections = document.querySelectorAll<HTMLElement>(".month-section");

        if (!select) return;

        select.addEventListener("change", () => {
            const val = select.value.toUpperCase();

            posts.forEach((post) => {
                const postCat = (post.getAttribute("data-cat") || "").trim().toUpperCase();
                if (val === "ALL" || postCat === val) {
                    post.classList.remove("is-hidden");
                } else {
                    post.classList.add("is-hidden");
                }
            });

            setTimeout(() => {
                monthSections.forEach((section) => {
                    const visible = section.querySelectorAll(".note-wrapper:not(.is-hidden)");
                    section.classList.toggle("month-hidden", visible.length === 0);
                });
            }, 100);
        });
    };

    document.addEventListener("DOMContentLoaded", setupFilters);
    document.addEventListener("astro:page-load", setupFilters);
</script>

<style>
    .blog-archive {
        max-width: 1400px;
        margin: 2rem auto;
        padding: 0;
        font-family: "Noto Serif TC", serif;
    }

    .archive-header h1 {
        font-size: 1.6rem;
        margin: 0;
        font-weight: 700;
        letter-spacing: -1.5px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }
    .archive-header h1 small {
        font-size: 0.75rem;
        font-family: sans-serif;
        letter-spacing: 4px;
        color: var(--muted);
        font-weight: 400;
    }

    .header-line { width: 100%; height: 1px; background: var(--border); margin: 1.2rem 0 1.5rem; position: relative; }
    .header-line::after { content: ''; position: absolute; left: 0; top: -1px; width: 80px; height: 3px; background: var(--accent); }

    /* 分類篩選 */
    .category-filter { display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem; }
    .filter-label { font-size: 0.6rem; font-family: sans-serif; letter-spacing: 2px; color: var(--muted); font-weight: 700; text-transform: uppercase; white-space: nowrap; }
    .select-wrapper { position: relative; display: inline-flex; align-items: center; }
    .category-select {
        appearance: none; -webkit-appearance: none;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 0.35rem 2rem 0.35rem 0.8rem;
        font-size: 0.8rem;
        font-family: "Noto Serif TC", serif;
        color: var(--ink);
        cursor: pointer;
        transition: border-color 0.3s, color 0.3s;
        min-width: 180px;
    }
    .category-select:focus { outline: none; border-color: var(--accent); }
    .category-select:hover { border-color: var(--accent); color: var(--accent); }
    .select-arrow {
        position: absolute; right: 0.6rem;
        font-size: 0.6rem; color: var(--muted);
        pointer-events: none; transition: color 0.3s;
    }
    .select-wrapper:hover .select-arrow { color: var(--accent); }

    /* 月份分組 */
    .month-section { margin-bottom: 3.5rem; transition: opacity 0.4s ease, transform 0.4s ease; }
    .month-section.month-hidden { opacity: 0; height: 0; margin-bottom: 0; overflow: hidden; pointer-events: none; }

    .month-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 0.8rem;
        border-bottom: 2px solid var(--ink);
        margin-bottom: 0.8rem;
    }
    .month-name-group .prefix {
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: var(--muted);
        font-family: sans-serif;
        display: block;
        margin-bottom: 0.3rem;
    }
    .month-title { font-size: 1.4rem; margin: 0; color: var(--ink); font-weight: 700; }
    .note-count {
        font-size: 0.72rem;
        color: var(--accent);
        font-weight: 700;
        font-family: sans-serif;
        letter-spacing: 1px;
    }

    /* 條目 */
    .note-wrapper { transition: opacity 0.4s ease, max-height 0.4s ease; max-height: 200px; overflow: visible; }
    .note-wrapper.is-hidden { opacity: 0; max-height: 0; pointer-events: none; overflow: hidden; }

    .blog-entry {
        display: flex;
        align-items: center;
        justify-content: space-between;
        text-decoration: none;
        color: inherit;
        padding: 0.9rem 0;
        border-bottom: 1px dashed var(--border);
        transition: 0.4s ease;
    }
    .blog-entry:hover { background: rgba(139, 69, 19, 0.02); padding-left: 1.5rem; }

    .title-swap-container {
        flex: 1;
        position: relative;
        height: 1.5rem;
        overflow: hidden;
        display: flex;
        align-items: center;
    }
    .title-default, .title-hover {
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
        white-space: nowrap;
        line-height: 1.5rem;
    }
    .title-hover {
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
        transform: translateY(15px);
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .cat-tag {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--accent);
        background: rgba(139, 69, 19, 0.1);
        padding: 2px 8px;
        border-radius: 4px;
        font-family: sans-serif;
    }
    .sub-tag {
        font-size: 0.75rem;
        color: var(--muted);
        font-weight: 400;
        font-family: sans-serif;
    }

    .blog-entry:hover .title-default { opacity: 0; transform: translateY(-15px); }
    .blog-entry:hover .title-hover { opacity: 1; transform: translateY(0); }

    .entry-arrow {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.75rem;
        letter-spacing: 2px;
        color: var(--muted);
        opacity: 0.4;
        transition: 0.4s;
        font-family: sans-serif;
    }
    .blog-entry:hover .entry-arrow { opacity: 1; color: var(--accent); transform: translateX(5px); }
    .view-text { font-weight: 700; }

    @media (max-width: 850px) {
        .blog-archive { margin: 2rem auto; }
        .archive-header h1 { font-size: 2.5rem; flex-direction: column; gap: 0.5rem; }
        .month-title { font-size: 1.6rem; }
        .title-default, .title-hover { font-size: 1.1rem; }
        .entry-arrow .view-text { display: none; }
    }
</style>
