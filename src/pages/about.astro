<script is:inline>
  (function() {
    let currentLang = 'zh';

    function applyLanguage(lang) {
      currentLang = lang;

      // 切換所有內容元素（但排除語言切換按鈕內的元素）
      const allElements = document.querySelectorAll('[data-lang]');
      allElements.forEach((el) => {
        // 跳過語言切換按鈕內的選項元素
        if (el.classList.contains('lang-option')) {
          return;
        }

        const elLang = el.getAttribute('data-lang');
        if (elLang === lang) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });

      // 更新按鈕樣式
      const options = document.querySelectorAll('#lang-toggle .lang-option');
      options.forEach((opt) => {
        const optLang = opt.getAttribute('data-lang');
        if (optLang === lang) {
          opt.classList.add('active');
        } else {
          opt.classList.remove('active');
        }
        // 確保按鈕選項永遠可見
        opt.style.display = '';
      });
    }

    function handleClick(e) {
      // 不管點擊按鈕的哪個位置，都切換到另一個語言
      const newLang = currentLang === 'zh' ? 'en' : 'zh';
      applyLanguage(newLang);
    }

    function init() {
      const btn = document.getElementById('lang-toggle');
      if (!btn) return;

      // 檢查是否已經初始化過
      if (btn.hasAttribute('data-lang-setup')) return;

      // 標記為已設置
      btn.setAttribute('data-lang-setup', 'true');

      // 綁定點擊事件
      btn.removeEventListener('click', handleClick);
      btn.addEventListener('click', handleClick);

      // 初始化時強制應用中文
      applyLanguage('zh');
    }

    // 初始化
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(init, 50);
      });
    } else {
      setTimeout(init, 50);
    }

    // Astro 轉場支援
    document.addEventListener('astro:page-load', function() {
      currentLang = 'zh';
      setTimeout(init, 50);
    });
  })();
</script>

