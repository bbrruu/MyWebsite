---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allJournalPosts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allResearchPosts = (await getCollection("research")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allReadingPosts = (await getCollection("reading")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allMusicPosts = (await getCollection("music")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allNotesPosts = (await getCollection("notes")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allProjects = (await getCollection("projects")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredProjects = allProjects
    .filter((p: CollectionEntry<"projects">) => p.data.featured)
    .slice(0, 3);

const slogans = [
    "想買一桶冰淇淋暴挖起來吃",
    "有一隻貓咪叫做高麗菜",
    "中文字體要什麼才會好看呢",
    "蛋餅蛋餅九層塔蛋餅",
];
const randomSlogan = slogans[Math.floor(Math.random() * slogans.length)];

const slides = [
    {
        name: "生活隨筆", en: "JOURNAL", unit: "篇",
        href: "/blog", count: allJournalPosts.length,
        latest: allJournalPosts[0]?.data.title ?? null,
    },
    {
        name: "學習筆記", en: "NOTES", unit: "篇",
        href: "/notes", count: allNotesPosts.length,
        latest: allNotesPosts[0]?.data.title ?? null,
    },
    {
        name: "讀讀文獻", en: "RESEARCH", unit: "篇",
        href: "/research", count: allResearchPosts.length,
        latest: allResearchPosts[0]?.data.title ?? null,
    },
    {
        name: "看看書籍", en: "READING", unit: "本",
        href: "/reading", count: allReadingPosts.length,
        latest: allReadingPosts[0]?.data.title ?? null,
    },
    {
        name: "聽聽音樂", en: "MUSIC", unit: "首",
        href: "/music", count: allMusicPosts.length,
        latest: allMusicPosts[0]
            ? `${allMusicPosts[0].data.artist} — ${allMusicPosts[0].data.songName}`
            : null,
    },
    {
        name: "作品集", en: "PROJECTS", unit: "個",
        href: "/projects", count: allProjects.length,
        latest: allProjects[0]?.data.title ?? null,
    },
];
---

<Layout title="Bruce 個人網站">

    <!-- ══ HERO：上下各半，整頁高 ══ -->
    <section id="hero-section" class="hero-section">

        <!-- 上半：相框 banner -->
        <div class="hero-top">
            <a href="/about" class="banner-link-wrapper">
                <div class="banner-content">
                    <h1 class="banner-title" style="font-style: italic;">Bruce's Website</h1>
                    <div id="slogan" class="banner-slogan">{randomSlogan}</div>
                </div>
            </a>
        </div>

        <!-- 下半：Carousel -->
        <div class="hero-bottom">
            <div class="c-layout">
                <button id="c-prev" class="c-arrow" aria-label="上一個">←</button>

                <div class="c-track" id="c-track">
                    <!-- About card (index 0) -->
                    <a href="/about" class="c-slide c-slide--active" data-idx="0">
                        <div class="cs-header">
                            <span class="cs-en">ABOUT</span>
                            <span class="cs-sep">·</span>
                            <span class="cs-name">關於我</span>
                        </div>
                        <div class="cs-about-body">
                            <div class="cs-about-photo">
                                <img src="/images/profile.jpg" alt="Bruce" transition:name="profile-photo" />
                            </div>
                            <span class="cs-about-name">曾冠瑜</span>
                            <span class="cs-about-sub">Bruce Tseng</span>
                        </div>
                        <div class="cs-footer">
                            <span class="cs-label">查看</span>
                            <span class="cs-latest">個人簡介</span>
                            <span class="cs-go">→</span>
                        </div>
                    </a>

                    {slides.map((slide, i) => (
                        <a
                            href={slide.href}
                            class="c-slide"
                            data-idx={i + 1}
                        >
                            <!-- 頂部：英文 + 中文 -->
                            <div class="cs-header">
                                <span class="cs-en">{slide.en}</span>
                                <span class="cs-sep">·</span>
                                <span class="cs-name">{slide.name}</span>
                            </div>

                            <!-- 中央：數字 -->
                            <div class="cs-body">
                                <span class="cs-count">{slide.count}</span>
                                <span class="cs-unit">{slide.unit}</span>
                            </div>

                            <!-- 底部：最新一篇 -->
                            <div class="cs-footer">
                                <span class="cs-label">最新</span>
                                <span class="cs-latest">
                                    {slide.latest ? `〈${slide.latest}〉` : "尚無內容"}
                                </span>
                                <span class="cs-go">→</span>
                            </div>
                        </a>
                    ))}
                </div>

                <button id="c-next" class="c-arrow" aria-label="下一個">→</button>
            </div>

            <!-- Dots -->
            <div class="c-dots" id="c-dots">
                <!-- About dot (index 0) -->
                <button class="c-dot active" data-idx="0" aria-label="第 1 項"></button>
                {slides.map((_, i) => (
                    <button
                        class="c-dot"
                        data-idx={i + 1}
                        aria-label={`第 ${i + 2} 項`}
                    ></button>
                ))}
            </div>
        </div>
    </section>

    <!-- ══ 內容區：snap point，之後正常 scroll ══ -->
    <div id="content-section" class="content-section">

        {featuredProjects.length > 0 && (
            <section class="featured-projects">
                <div class="fp-header">
                    <div class="fp-title-group">
                        <span class="fp-label">SIDE PROJECTS</span>
                        <h2 class="fp-title">作品集 <span class="fp-sub">FEATURED WORKS</span></h2>
                    </div>
                    <a href="/projects" class="fp-view-all">查看全部 →</a>
                </div>
                <div class="fp-grid">
                    {featuredProjects.map((project: CollectionEntry<"projects">) => (
                        <a href={`/projects/${project.id}`} class="fp-card">
                            <div class="fp-cover">
                                {project.data.coverImage
                                    ? <img src={project.data.coverImage} alt={project.data.title} />
                                    : <div class="fp-cover-placeholder"><span>{project.data.techStack[0] || "?"}</span></div>
                                }
                                <span class={`fp-status fp-status--${project.data.status.toLowerCase()}`}>
                                    {project.data.status}
                                </span>
                            </div>
                            <div class="fp-info">
                                <h3 class="fp-name">{project.data.title}</h3>
                                <p class="fp-desc">{project.data.description}</p>
                                <div class="fp-tags">
                                    {project.data.techStack.slice(0, 3).map((tech: string) => (
                                        <span class="fp-tag">{tech}</span>
                                    ))}
                                </div>
                                <div class="fp-links">
                                    {project.data.demoUrl && <span class="fp-link-badge">Demo</span>}
                                    {project.data.githubUrl && <span class="fp-link-badge">GitHub</span>}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}

        <section class="featured-music">
            <div class="fp-header">
                <div class="fp-title-group">
                    <span class="fp-label">SOUND & TRACKS</span>
                    <h2 class="fp-title">聽聽音樂 <span class="fp-sub">RECENT PICKS</span></h2>
                </div>
                <a href="/music" class="fp-view-all">查看全部 →</a>
            </div>
            <div class="fm-grid">
                {allMusicPosts.slice(0, 3).map((post) => (
                    <a href={`/music/${post.id}`} class="fm-card">
                        <div class="fm-cover">
                            {post.data.youtubeId
                                ? <img src={`https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`} alt={post.data.songName} />
                                : <div class="fm-cover-placeholder"><span>{post.data.artist}</span></div>
                            }
                            <span class="fm-artist">{post.data.artist}</span>
                        </div>
                        <div class="fm-info">
                            <h3 class="fm-songname">《{post.data.songName}》</h3>
                            <p class="fm-desc">{post.data.title}</p>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <div class="quad-grid">
            <section class="home-section">
                <a href="/blog" class="section-title-link">
                    <div class="title-container">
                        <h2 class="section-title">生活隨筆<div class="hover-accent-line"></div></h2>
                        <span class="section-en">JOURNAL</span>
                    </div>
                    <span class="enter-arrow">→</span>
                </a>
                <div class="section-content">
                    {allJournalPosts.slice(0, 3).map((post) => (
                        <a href={`/blog/${post.id}`} class="preview-item">
                            <div class="preview-date">
                                <span class="p-year">{post.data.pubDate.getFullYear()}</span>
                                <span class="p-day">{post.data.pubDate.getDate()}日</span>
                            </div>
                            <div class="preview-body">
                                <h3 class="p-title">{post.data.title}</h3>
                                <p class="p-excerpt">{post.data.mood || "今日無事"}</p>
                            </div>
                        </a>
                    ))}
                    <div class="see-more-wrapper">
                        <a href="/blog" class="see-more-btn">查看更多 MORE<div class="btn-line"></div></a>
                    </div>
                </div>
            </section>

            <section class="home-section">
                <a href="/research" class="section-title-link">
                    <div class="title-container">
                        <h2 class="section-title">讀讀文獻<div class="hover-accent-line"></div></h2>
                        <span class="section-en">LITERATURE</span>
                    </div>
                    <span class="enter-arrow">→</span>
                </a>
                <div class="section-content">
                    {allResearchPosts.slice(0, 3).map((post) => (
                        <a href={`/research/${post.id}`} class="preview-item">
                            <div class="preview-date">
                                <span class="p-year">{post.data.pubDate.getFullYear()}</span>
                                <span class="p-day">{post.data.pubDate.getDate()}日</span>
                            </div>
                            <div class="preview-body">
                                <h3 class="p-title">{post.data.title}</h3>
                                <p class="p-excerpt">{post.data.category || "學術探究"}</p>
                            </div>
                        </a>
                    ))}
                    <div class="see-more-wrapper">
                        <a href="/research" class="see-more-btn">查看更多 MORE<div class="btn-line"></div></a>
                    </div>
                </div>
            </section>

            <section class="home-section">
                <a href="/reading" class="section-title-link">
                    <div class="title-container">
                        <h2 class="section-title">看看書籍<div class="hover-accent-line"></div></h2>
                        <span class="section-en">READING</span>
                    </div>
                    <span class="enter-arrow">→</span>
                </a>
                <div class="section-content">
                    {allReadingPosts.slice(0, 3).map((post) => (
                        <a href={`/reading/${post.id}`} class="preview-item">
                            <div class="preview-date">
                                <span class="p-year">{post.data.pubDate.getFullYear()}</span>
                                <span class="p-day">{post.data.pubDate.getDate()}日</span>
                            </div>
                            <div class="preview-body">
                                <h3 class="p-title">{post.data.title}</h3>
                                <p class="p-excerpt">{post.data.author || "書海拾貝"}</p>
                            </div>
                        </a>
                    ))}
                    <div class="see-more-wrapper">
                        <a href="/reading" class="see-more-btn">查看更多 MORE<div class="btn-line"></div></a>
                    </div>
                </div>
            </section>

            <section class="home-section">
                <a href="/notes" class="section-title-link">
                    <div class="title-container">
                        <h2 class="section-title">學習筆記<div class="hover-accent-line"></div></h2>
                        <span class="section-en">FIELD NOTES</span>
                    </div>
                    <span class="enter-arrow">→</span>
                </a>
                <div class="section-content">
                    {allNotesPosts.slice(0, 3).map((note) => (
                        <a href={`/notes/${note.id}`} class="preview-item">
                            <div class="preview-date">
                                <span class="p-year">{note.data.pubDate.getFullYear()}</span>
                                <span class="p-day">{note.data.pubDate.getDate()}日</span>
                            </div>
                            <div class="preview-body">
                                <h3 class="p-title">{note.data.title}</h3>
                                <p class="p-excerpt">{note.data.category || "學習筆記"}</p>
                            </div>
                        </a>
                    ))}
                    <div class="see-more-wrapper">
                        <a href="/notes" class="see-more-btn">查看更多 MORE<div class="btn-line"></div></a>
                    </div>
                </div>
            </section>
        </div>

    </div><!-- end content-section -->

</Layout>

<script is:inline define:vars={{ slogans, randomSlogan }}>
    var _cleanups = [];

    // ── 清除所有 cleanup ──────────────────────────────────────
    document.addEventListener("astro:before-preparation", function () {
        _cleanups.forEach(function (fn) { fn(); });
        _cleanups = [];
        document.documentElement.classList.remove("hp-snap");
    });

    // ── 字卡展開動畫：延遲 Astro 換頁，讓 cover 先跑完（只註冊一次）──
    if (!window._cardNavDelayAdded) {
        window._cardNavDelayAdded = true;
        document.addEventListener("astro:before-preparation", function (e) {
            if (!document.documentElement.classList.contains("card-nav")) return;
            var orig = e.loader;
            e.loader = function () {
                return new Promise(function (r) { setTimeout(r, 340); })
                    .then(function () { return orig(); });
            };
        });
    }

    // ── 換頁後清除 card-nav class ────────────────────────────────
    document.addEventListener("astro:page-load", function () {
        document.documentElement.classList.remove("card-nav");
    });

    // ── Scroll Snap 啟動 ──────────────────────────────────────
    function initScrollSnap() {
        var nav = document.querySelector(".sticky-nav");
        var navH = nav ? nav.offsetHeight : 50;
        document.documentElement.style.setProperty("--nav-h", navH + "px");
        document.documentElement.classList.add("hp-snap");

        // 視窗大小改變時重算
        function onResize() {
            var n = document.querySelector(".sticky-nav");
            var h = n ? n.offsetHeight : 50;
            document.documentElement.style.setProperty("--nav-h", h + "px");
        }
        window.addEventListener("resize", onResize);
        _cleanups.push(function () { window.removeEventListener("resize", onResize); });
    }

    // ── Carousel（撲克疊牌）────────────────────────────────────
    function initCarousel() {
        var track   = document.getElementById("c-track");
        var prevBtn = document.getElementById("c-prev");
        var nextBtn = document.getElementById("c-next");
        var dots    = Array.from(document.querySelectorAll(".c-dot"));
        var slides  = Array.from(document.querySelectorAll(".c-slide"));

        if (!track || !slides.length) return;

        var TOTAL     = slides.length;
        var cur       = 0;
        var dragMoved = false;

        // 每個 offset 層的設定
        // offset 0 = 正中央, ±1 = 第一層疊牌, ±2 = 第二層疊牌
        var CFG = [
            { xFrac: 0,    rot: 0,  scale: 1,    opacity: 1,    z: 10 },
            { xFrac: 0.26, rot: 10, scale: 0.86, opacity: 0.85, z: 7  },
            { xFrac: 0.40, rot: 18, scale: 0.76, opacity: 0.70, z: 5  },
        ];
        // offset ±3 以上：預備位置，opacity 0（seamless 出現用）
        var GHOST = { xFrac: 0.50, rot: 22, scale: 0.68, opacity: 0, z: 1 };

        function applyPos(slide, offset) {
            var abs  = Math.abs(offset);
            var sign = offset >= 0 ? 1 : -1;
            var cfg  = abs <= 2 ? CFG[abs] : GHOST;
            var x    = sign * track.offsetWidth * cfg.xFrac;

            slide.style.transform     = "translateX(calc(-50% + " + x + "px)) translateY(-50%) rotate(" + (sign * cfg.rot) + "deg) scale(" + cfg.scale + ")";
            slide.style.opacity       = String(cfg.opacity);
            slide.style.zIndex        = String(cfg.z);
            // 只有 active 可點擊觸發連結，側牌點擊切換
            slide.style.pointerEvents = "";
        }

        // ── 牌尺寸計算 ──
        function updateLayout() {
            var h  = track.offsetHeight;
            var w  = track.offsetWidth;
            var cH = Math.round(h * 0.84);
            var isMobile = w < 500;
            var cW = isMobile
                ? Math.round(Math.min(w * 0.68, 240))
                : Math.round(Math.min(w * 0.36, 260));
            slides.forEach(function (s) {
                s.style.height = cH + "px";
                s.style.width  = cW + "px";
            });
            posAll();
        }

        function posAll() {
            slides.forEach(function (s, i) { applyPos(s, i - cur); });
        }

        var resizeH = function () { updateLayout(); };
        window.addEventListener("resize", resizeH);
        _cleanups.push(function () { window.removeEventListener("resize", resizeH); });

        // ── 切換到指定 index ──
        function goTo(i) {
            cur = Math.max(0, Math.min(TOTAL - 1, i));
            posAll();
            dots.forEach(function (d, idx) { d.classList.toggle("active", idx === cur); });
            if (prevBtn) prevBtn.disabled = cur === 0;
            if (nextBtn) nextBtn.disabled = cur === TOTAL - 1;
        }

        // 初始化
        updateLayout();
        goTo(0);

        // 側牌點擊 → 切換；active 牌點擊 → JS cover 展開動畫
        slides.forEach(function (s, i) {
            s.addEventListener("click", function (e) {
                if (dragMoved) { e.preventDefault(); dragMoved = false; return; }
                if (i !== cur) { e.preventDefault(); goTo(i); return; }

                // Active card：建立 cover div，從卡片位置展開到全螢幕
                var rect = s.getBoundingClientRect();
                var cover = document.createElement("div");
                cover.style.cssText =
                    "position:fixed;z-index:9990;pointer-events:none;" +
                    "background:var(--paper);border-radius:6px;" +
                    "top:" + rect.top + "px;" +
                    "left:" + rect.left + "px;" +
                    "width:" + rect.width + "px;" +
                    "height:" + rect.height + "px;" +
                    "transition:" +
                    "top .32s cubic-bezier(.4,0,.2,1)," +
                    "left .32s cubic-bezier(.4,0,.2,1)," +
                    "width .32s cubic-bezier(.4,0,.2,1)," +
                    "height .32s cubic-bezier(.4,0,.2,1)," +
                    "border-radius .32s;";
                document.body.appendChild(cover);

                // 標記 card-nav（讓 loader 延遲 + 讓 CSS 關閉 view transition）
                document.documentElement.classList.add("card-nav");

                // 展開到全螢幕
                requestAnimationFrame(function () {
                    requestAnimationFrame(function () {
                        cover.style.top = "0px";
                        cover.style.left = "0px";
                        cover.style.width = "100vw";
                        cover.style.height = "100vh";
                        cover.style.borderRadius = "0px";
                    });
                });
                // 讓連結正常導航（不 preventDefault），loader delay 會等動畫跑完
            });
        });

        // ── 箭頭 ──
        prevBtn && prevBtn.addEventListener("click", function () { goTo(cur - 1); });
        nextBtn && nextBtn.addEventListener("click", function () { goTo(cur + 1); });

        // ── Dots ──
        dots.forEach(function (d, i) { d.addEventListener("click", function () { goTo(i); }); });

        // ── Touch ──
        var touchStartX = 0;
        track.addEventListener("touchstart", function (e) {
            touchStartX = e.touches[0].clientX;
        }, { passive: true });
        track.addEventListener("touchend", function (e) {
            var diff = touchStartX - e.changedTouches[0].clientX;
            if (diff >  55 && cur < TOTAL - 1) goTo(cur + 1);
            else if (diff < -55 && cur > 0)    goTo(cur - 1);
        }, { passive: true });

        // ── Mouse drag ──
        var isDragging = false, dragStartX = 0;

        track.addEventListener("mousedown", function (e) {
            isDragging = true;
            dragMoved  = false;
            dragStartX = e.clientX;
            e.preventDefault();
        });

        var mmH = function (e) {
            if (!isDragging) return;
            if (Math.abs(e.clientX - dragStartX) > 8) dragMoved = true;
        };
        var muH = function (e) {
            if (!isDragging) return;
            isDragging = false;
            var diff = dragStartX - e.clientX;
            if (diff >  55 && cur < TOTAL - 1) goTo(cur + 1);
            else if (diff < -55 && cur > 0)    goTo(cur - 1);
        };
        window.addEventListener("mousemove", mmH);
        window.addEventListener("mouseup",   muH);
        _cleanups.push(function () {
            window.removeEventListener("mousemove", mmH);
            window.removeEventListener("mouseup",   muH);
        });
    }

    // ── 標語輪播 ──────────────────────────────────────────────
    function initSlogan() {
        var el = document.getElementById("slogan");
        if (window._sloganTimer) clearInterval(window._sloganTimer);
        if (!el) return;
        var idx = slogans.indexOf(randomSlogan);
        function next() {
            el.style.opacity = "0";
            setTimeout(function () {
                idx = (idx + 1) % slogans.length;
                el.textContent = slogans[idx];
                el.style.opacity = "1";
            }, 500);
        }
        window._sloganTimer = setInterval(next, 3000);
        _cleanups.push(function () { clearInterval(window._sloganTimer); });
    }

    // ── 入口 ──────────────────────────────────────────────────
    document.addEventListener("astro:page-load", function () {
        if (window.location.pathname !== "/") return;
        initScrollSnap();
        initCarousel();
        initSlogan();
    });
</script>

<style is:global>
    /* ── Scroll snap（僅首頁啟用）── */
    html.hp-snap {
        scroll-snap-type: y mandatory;
        scroll-padding-top: var(--nav-h, 50px);
    }
    html.hp-snap .hero-section    { scroll-snap-align: start; }
    html.hp-snap .content-section { scroll-snap-align: start; }

</style>

<style>
    /* ══ Layout ══════════════════════════════════════════════ */

    /* Hero section：全頁高 - navbar */
    .hero-section {
        height: calc(100dvh - var(--nav-h, 50px));
        display: flex;
        flex-direction: column;
        /* 突破 Layout 的 4rem 側邊距，做全寬 */
        margin-left:  -4rem;
        margin-right: -4rem;
        width: calc(100% + 8rem);
        overflow: hidden;
    }

    /* 內容區：snap 後正常 scroll */
    .content-section {
        padding-top: 2.5rem;
    }

    /* ══ Hero Top（Banner）════════════════════════════════════ */
