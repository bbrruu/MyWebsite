---
// ── 頁面介紹（可直接修改這段文字）──
const pageDesc = "Side Project的存放處，在這裡可以看到我Vibe Coding出來的一些應用。";

import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allProjects = (await getCollection("projects")).sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
        b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 年月分組
const groupedProjects = allProjects.reduce((acc, project) => {
    const d = project.data.pubDate;
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
    if (!acc[key]) acc[key] = { year: d.getFullYear(), month: d.getMonth() + 1, projects: [] as typeof allProjects };
    acc[key].projects.push(project);
    return acc;
}, {} as Record<string, { year: number; month: number; projects: typeof allProjects }>);

const projectGroups = Object.entries(groupedProjects)
    .sort(([a], [b]) => b.localeCompare(a))
    .map(([key, val]) => ({ key, ...val }));
---

<Layout title="作品集 | Side Projects - Bruce">
    <div class="paper-texture"></div>

    <main class="projects-archive">
        <header class="archive-header">
            <div class="header-row">
                <h1>作品集 <small>SIDE PROJECTS</small></h1>
                <p class="page-desc">{pageDesc}</p>
            </div>
            <div class="header-line"></div>
        </header>

        <div id="projects-list">
            {projectGroups.map((group) => (
                <section class="date-group">
                    <div class="group-header">
                        <span class="group-year">{group.year} 年</span>
                        <span class="group-month">{group.month} 月</span>
                        <div class="group-line"></div>
                        <span class="group-count">{group.projects.length} PROJECTS</span>
                    </div>
                    <div class="projects-grid">
                        {group.projects.map((project: CollectionEntry<"projects">) => (
                            <a href={`/projects/${project.id}`} class="project-card">
                                <div class="card-cover">
                                    {project.data.coverImage
                                        ? <img src={project.data.coverImage} alt={project.data.title} />
                                        : <div class="cover-placeholder"><span>{project.data.techStack[0] || "?"}</span></div>
                                    }
                                    <span class={`status-badge status--${project.data.status.toLowerCase()}`}>
                                        {project.data.status}
                                    </span>
                                </div>
                                <div class="card-body">
                                    <div class="card-meta">
                                        <span class="card-category">{project.data.category}</span>
                                    </div>
                                    <h2 class="card-title">{project.data.title}</h2>
                                    <p class="card-desc">{project.data.description}</p>
                                    <div class="card-tags">
                                        {project.data.techStack.map((tech: string) => (
                                            <span class="tech-tag">{tech}</span>
                                        ))}
                                    </div>
                                    <div class="card-links">
                                        {project.data.demoUrl && <span class="link-chip">Demo →</span>}
                                        {project.data.githubUrl && <span class="link-chip">GitHub →</span>}
                                    </div>
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </main>
</Layout>

<style>
    .projects-archive {
        max-width: 1400px;
        margin: 2rem auto;
        font-family: "LXGW WenKai TC", serif;
    }

    /* ── Header ── */
    .header-row { display: flex; align-items: flex-end; gap: 2.5rem; }
    .archive-header h1 { font-size: 1.6rem; margin: 0; font-weight: 700; letter-spacing: -1.5px; }
    .archive-header h1 small { font-size: 0.75rem; font-family: var(--font-mono); letter-spacing: 4px; color: var(--muted); font-weight: 400; margin-left: 0.6rem; }
    .page-desc { flex: 1; font-size: 0.82rem; color: var(--muted); line-height: 1.8; margin: 0 0 0.15rem 0; font-style: italic; padding-left: 2rem; border-left: 1px solid var(--border); }
    .header-line {
        width: 100%;
        height: 1px;
        background: var(--border);
        margin: 1.2rem 0 2rem;
        position: relative;
    }
    .header-line::after {
        content: '';
        position: absolute;
        left: 0;
        top: -1px;
        width: 80px;
        height: 3px;
        background: var(--accent);
    }

    /* ── Date group ── */
    .date-group { margin-bottom: 3rem; }

    .group-header {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        margin-bottom: 1.2rem;
    }
    .group-year { font-size: 0.62rem; font-family: var(--font-mono); letter-spacing: 2px; color: var(--muted); }
    .group-month { font-size: 1.15rem; font-weight: 700; color: var(--ink); letter-spacing: -0.5px; }
    .group-line { flex: 1; height: 1px; background: var(--border); align-self: center; }
    .group-count { font-size: 0.58rem; font-family: var(--font-mono); letter-spacing: 2px; color: var(--accent); font-weight: 700; }

    /* ── Grid ── */
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    /* ── Card ── */
    .project-card {
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        display: flex;
        flex-direction: column;
    }
    .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(139, 69, 19, 0.1);
        border-color: var(--accent);
    }

    .card-cover { position: relative; height: 180px; overflow: hidden; background: var(--border); }
    .card-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
    .project-card:hover .card-cover img { transform: scale(1.04); }
    .cover-placeholder {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(139,69,19,0.08), rgba(139,69,19,0.18));
    }
    .cover-placeholder span {
        font-family: var(--font-mono); font-size: 0.8rem; letter-spacing: 4px;
        color: var(--accent); text-transform: uppercase; font-weight: 700;
    }

    /* status badge：深色底白字 */
    .status-badge {
        position: absolute;
        top: 0.6rem;
        right: 0.6rem;
        font-size: 0.68rem;
        font-family: var(--font-mono);
        letter-spacing: 0.5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        background: rgba(20, 10, 5, 0.62);
        color: #fff;
        backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
    }
    /* 保留微妙色彩提示用底線 */
    .status--active  { box-shadow: inset 0 -2px 0 rgba(34, 197, 94, 0.7); }
    .status--wip     { box-shadow: inset 0 -2px 0 rgba(249, 115, 22, 0.7); }
    .status--archived{ box-shadow: inset 0 -2px 0 rgba(100, 116, 139, 0.7); }

    .card-body { padding: 1rem; display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
    .card-meta { display: flex; justify-content: space-between; align-items: center; }
    .card-category { font-size: 0.6rem; font-family: var(--font-mono); letter-spacing: 3px; color: var(--accent); text-transform: uppercase; font-weight: 700; }
    .card-title { font-size: 1.1rem; font-weight: 700; margin: 0; }
    .card-desc { font-size: 0.8rem; color: var(--muted); margin: 0; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: auto; padding-top: 0.3rem; }
    .tech-tag { font-size: 0.62rem; font-family: var(--font-mono); letter-spacing: 1px; padding: 2px 7px; border: 1px solid var(--border); border-radius: 3px; color: var(--muted); }
    .card-links { display: flex; gap: 0.5rem; }
    .link-chip { font-size: 0.65rem; font-family: var(--font-mono); letter-spacing: 1px; color: var(--accent); transition: 0.3s; }
    .project-card:hover .link-chip { color: var(--ink); }

    @media (max-width: 850px) {
        .projects-grid { grid-template-columns: repeat(2, 1fr); }
        .header-row { flex-direction: column; gap: 0.8rem; }
        .page-desc { border-left: none; padding-left: 0; }
        .archive-header h1 { font-size: 2.5rem; }
    }
    @media (max-width: 500px)  { .projects-grid { grid-template-columns: 1fr; } }
</style>
