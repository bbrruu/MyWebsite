---
// ── 頁面介紹（可直接修改這段文字）──
const pageDesc = "我會在這邊分享我喜歡的一些音樂以及我聽完歌曲後的心得感想。";

import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allMusic = (await getCollection("music")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const artists = [...new Set(allMusic.map((p) => p.data.artist || "佚名"))].sort();

const groupedMusic = allMusic.reduce((acc, post) => {
    const d = post.data.pubDate;
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
    if (!acc[key]) acc[key] = { year: d.getFullYear(), month: d.getMonth() + 1, posts: [] as typeof allMusic };
    acc[key].posts.push(post);
    return acc;
}, {} as Record<string, { year: number; month: number; posts: typeof allMusic }>);

const musicGroups = Object.entries(groupedMusic)
    .sort(([a], [b]) => b.localeCompare(a))
    .map(([key, val]) => ({ key, ...val }));

function getExcerpt(body: string, maxLen = 120): string {
    const text = body
        .replace(/^#+\s+/gm, '')
        .replace(/[*_`~>]/g, '')
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
        .replace(/\n+/g, ' ')
        .trim();
    return text.length > maxLen ? text.slice(0, maxLen).trimEnd() + '…' : text;
}
---

<Layout title="拾音集 | 樂評編目 - Bruce">
    <div class="paper-texture"></div>

    <main class="music-archive">
        <header class="archive-header">
            <div class="header-row">
                <h1>拾音集 <small>SOUND & TRACKS</small></h1>
                <p class="page-desc">{pageDesc}</p>
                <div class="archive-filter">
                    <div class="lang-filter">
                        <label class="filter-label">語系</label>
                        <div class="lang-tabs">
                            <button class="lang-tab active" data-lang="all">全部</button>
                            <span class="tab-div">/</span>
                            <button class="lang-tab" data-lang="chinese">中文</button>
                            <span class="tab-div">/</span>
                            <button class="lang-tab" data-lang="japanese">日文</button>
                            <span class="tab-div">/</span>
                            <button class="lang-tab" data-lang="western">歐美</button>
                            <span class="tab-div">/</span>
                            <button class="lang-tab" data-lang="other">其他</button>
                        </div>
                    </div>
                    <div class="artist-filter">
                        <label for="artist-select" class="filter-label">FILTER</label>
                        <div class="select-wrapper">
                            <select id="artist-select" class="filter-select">
                                <option value="all">全部 ALL</option>
                                {artists.map((artist) => (
                                    <option value={artist}>{artist}</option>
                                ))}
                            </select>
                            <span class="select-arrow">↓</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="header-line"></div>
        </header>

        <div class="two-panel-layout">

            <aside class="cd-panel">
                <div class="cd-gesture-zone" id="cd-zone">
                    <button class="cd-arrow" id="cd-arrow-up">&#8592;</button>
                    <div class="cd-wrap">
                        <div class="cd-disc" id="cd-disc">
                            <div class="cd-art" id="cd-art"></div>
                            <div class="cd-grooves"></div>
                            <div class="cd-shine"></div>
                            <div class="cd-spindle"></div>
                        </div>
                    </div>
                    <button class="cd-arrow" id="cd-arrow-down">&#8594;</button>
                </div>
                <div class="cd-meta">
                    <p class="cd-songname" id="cd-songname">— —</p>
                    <p class="cd-artist" id="cd-artist">—</p>
                </div>
                <p class="cd-excerpt" id="cd-excerpt"></p>
            </aside>

            <section class="grid-panel">
                <div id="music-grid">
                    {musicGroups.map((group) => (
                        <section class="date-group" data-group={group.key}>
                            <div class="group-header">
                                <span class="group-year">{group.year} 年</span>
                                <span class="group-month">{group.month} 月</span>
                                <div class="group-line"></div>
                                <span class="group-count">{group.posts.length} TRACKS</span>
                            </div>
                            <div class="mc-grid">
                                {group.posts.map((post) => (
                                    <a
                                        href={`/music/${post.id}`}
                                        class="mc-card"
                                        data-artist={post.data.artist || "佚名"}
                                        data-language={post.data.language || "other"}
                                        data-youtube-id={post.data.youtubeId || ""}
                                        data-song-name={post.data.songName || ""}
                                        data-desc={getExcerpt(post.body ?? '')}
                                    >
                                        <div class="mc-cover">
                                            {post.data.youtubeId
                                                ? <img class="mc-thumb" src={`https://img.youtube.com/vi/${post.data.youtubeId}/hqdefault.jpg`} alt={post.data.songName} loading="lazy" />
                                                : <div class="mc-thumb-placeholder"><span>{post.data.artist}</span></div>
                                            }
                                            {post.data.youtubeId && (
                                                <div class="mc-yt-wrapper">
                                                    <div class="mc-yt-target"></div>
                                                </div>
                                            )}
                                            <div class="mc-hover-overlay">
                                                <span class="mc-play-icon">▶</span>
                                                <span class="mc-hover-hint">懸停播放</span>
                                            </div>
                                            <span class="mc-artist-badge">{post.data.artist}</span>
                                        </div>
                                        <div class="mc-info">
                                            <h3 class="mc-songname">《{post.data.songName}》</h3>
                                            <p class="mc-desc">{post.data.title}</p>
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </section>
                    ))}
                </div>
            </section>

        </div>
    </main>

    <!-- 底部迷你播放器 -->
    <div id="mini-player" class="mini-player">
        <div class="mp-info">
            <span class="mp-song" id="mp-song"></span>
            <span class="mp-artist" id="mp-artist"></span>
        </div>
        <div class="mp-controls">
            <button id="mp-playpause" class="mp-btn mp-playpause">⏸</button>
            <div class="mp-progress-area">
                <span class="mp-time" id="mp-cur">0:00</span>
                <input type="range" id="mp-bar" class="mp-bar" min="0" max="1000" value="0" step="1">
                <span class="mp-time" id="mp-dur">0:00</span>
            </div>
        </div>
        <button id="mp-close" class="mp-btn mp-close-btn">✕</button>
    </div>
</Layout>

<script is:inline>
    // ── YouTube IFrame API 初始化 ──────────────────────────────────────
    if (!window.__ytApiListenerSet) {
        window.__ytApiListenerSet = true;
        window.onYouTubeIframeAPIReady = function () { window.ytApiReady = true; };
    }
    if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
        var s = document.createElement('script');
        s.src = 'https://www.youtube.com/iframe_api';
        document.head.appendChild(s);
    }
    if (window.YT && window.YT.Player) window.ytApiReady = true;

    // ── 全域清理參考（頁面切換用）────────────────────────────────────
    if (!window.__musicCleanupSet) {
        window.__musicCleanupSet = true;
        document.addEventListener('astro:before-preparation', function () {
            if (window.__musicStop) { window.__musicStop(); window.__musicStop = null; }
        });
    }

    // ── 主邏輯 ────────────────────────────────────────────────────────
    function musicSetup() {
        var ytPlayer    = null;
        var activeCard  = null;
        var pollTimer   = null;
        var isDragging  = false;
        var switchTimer = null;   // 3 秒切歌防抖

        var miniPlayer  = document.getElementById('mini-player');
        var mpPlayPause = document.getElementById('mp-playpause');
        var mpClose     = document.getElementById('mp-close');
        var mpBar       = document.getElementById('mp-bar');
        var mpCur       = document.getElementById('mp-cur');
        var mpDur       = document.getElementById('mp-dur');
        var mpSong      = document.getElementById('mp-song');
        var mpArtist    = document.getElementById('mp-artist');

        if (!miniPlayer) return;

        // ── CD 狀態 ──
        var allCards = Array.from(document.querySelectorAll('.mc-card[data-youtube-id]'));
        var cdIndex  = -1;
        var cdDisc   = document.getElementById('cd-disc');
        var cdArt    = document.getElementById('cd-art');
        var cdZone   = document.getElementById('cd-zone');
        var cdSongEl    = document.getElementById('cd-songname');
        var cdArtEl     = document.getElementById('cd-artist');
        var cdExcerptEl = document.getElementById('cd-excerpt');

        // ── 工具函式 ──
        function fmt(sec) {
            if (!isFinite(sec) || isNaN(sec)) return '0:00';
            var m = Math.floor(sec / 60), s = Math.floor(sec % 60);
            return m + ':' + (s < 10 ? '0' : '') + s;
        }

        function fillBar(pct) {
            mpBar.style.background =
                'linear-gradient(to right, var(--accent) ' + pct + '%, rgba(255,255,255,0.18) ' + pct + '%)';
        }

        function tick() {
            if (!ytPlayer || !ytPlayer.getCurrentTime || isDragging) return;
            try {
                var cur = ytPlayer.getCurrentTime();
                var dur = ytPlayer.getDuration();
                if (!dur) return;
                var pct = (cur / dur) * 100;
                mpBar.value = Math.round((cur / dur) * 1000);
                mpCur.textContent = fmt(cur);
                mpDur.textContent = fmt(dur);
                fillBar(pct);
            } catch (_) {}
        }

        // ── 設定播放按鈕文字與樣式 ──
        function setMpBtn(text) {
            mpPlayPause.textContent = text;
            var isLong = text.length > 2;
            mpPlayPause.style.width         = isLong ? 'auto' : '';
            mpPlayPause.style.padding       = isLong ? '0 10px' : '';
            mpPlayPause.style.fontSize      = isLong ? '0.68rem' : '';
            mpPlayPause.style.letterSpacing = isLong ? '0.5px' : '';
        }

        // ── CD 更新 ──
        function syncCdToCard(card) {
            cdIndex = allCards.indexOf(card);
            var ytId = card.dataset.youtubeId || '';
            if (cdArt) cdArt.style.backgroundImage = ytId
                ? 'url(https://img.youtube.com/vi/' + ytId + '/hqdefault.jpg)' : '';
            if (cdSongEl)    cdSongEl.textContent    = card.dataset.songName ? '《' + card.dataset.songName + '》' : '— —';
            if (cdArtEl)     cdArtEl.textContent     = card.dataset.artist || '—';
            if (cdExcerptEl) cdExcerptEl.textContent = card.dataset.desc || '';
            allCards.forEach(function(c) { c.classList.remove('cd-selected'); });
            card.classList.add('cd-selected');
        }

        function setCdSpin(playing) {
            if (cdDisc) cdDisc.classList.toggle('is-spinning', playing);
        }

        function cdCycle(dir) {
            var visible = allCards.filter(function(c) { return c.style.display !== 'none'; });
            if (!visible.length) return;
            var cur  = visible.indexOf(allCards[cdIndex]);
            var next = cur === -1 ? (dir > 0 ? 0 : visible.length - 1)
                                  : (cur + dir + visible.length) % visible.length;
            var target = visible[next];
            syncCdToCard(target);
            activateCard(target);
            var arrowEl = dir > 0 ? document.getElementById('cd-arrow-down') : document.getElementById('cd-arrow-up');
            if (arrowEl) { arrowEl.classList.add('flash'); setTimeout(function() { arrowEl.classList.remove('flash'); }, 300); }
            target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // ── 停止清理 ──
        function stopPlayer() {
            setCdSpin(false);
            if (pollTimer)  { clearInterval(pollTimer); pollTimer = null; }
            if (ytPlayer)   { try { ytPlayer.destroy(); } catch (_) {} ytPlayer = null; }
            if (activeCard) { activeCard.classList.remove('active'); activeCard = null; }
            if (miniPlayer) miniPlayer.classList.remove('active');
            mpBar.value = 0;
            fillBar(0);
        }
        window.__musicStop = stopPlayer;

        // ── 建立播放器 ──
        function createPlayer(card, ytId) {
            var wrapper = card.querySelector('.mc-yt-wrapper');
            if (!wrapper) return;

            // 清除舊 iframe，重新插入 target div
            wrapper.innerHTML = '';
            var target = document.createElement('div');
            wrapper.appendChild(target);

            ytPlayer = new YT.Player(target, {
                videoId: ytId,
                playerVars: { autoplay: 1, controls: 0, loop: 1, playlist: ytId, playsinline: 1, rel: 0, modestbranding: 1 },
                events: {
                    onReady: function (e) {
                        e.target.playVideo();

                        // 把 YT 建立的 iframe 撐滿 wrapper
                        var iframe = wrapper.querySelector('iframe');
                        if (iframe) {
                            iframe.style.position    = 'absolute';
                            iframe.style.top         = '0';
                            iframe.style.left        = '0';
                            iframe.style.width       = '100%';
                            iframe.style.height      = '100%';
                            iframe.style.border      = 'none';
                            iframe.style.pointerEvents = 'none';
                        }

                        card.classList.add('active');

                        // 更新 mini player
                        mpSong.textContent   = '《' + (card.dataset.songName || '') + '》';
                        mpArtist.textContent = card.dataset.artist || '';
                        setMpBtn('點擊我播放');
                        mpDur.textContent    = fmt(e.target.getDuration());
                        miniPlayer.classList.add('active');

                        if (pollTimer) clearInterval(pollTimer);
                        pollTimer = setInterval(tick, 250);
                    },
                    onStateChange: function (e) {
                        // YT.PlayerState: 1=playing, 2=paused, 0=ended
                        if (e.data === 1)      { setMpBtn('⏸'); setCdSpin(true); }
                        else if (e.data === 2) { setMpBtn('▶'); setCdSpin(false); }
                        else if (e.data === 0) { setMpBtn('▶'); setCdSpin(false); }
                    }
                }
            });
        }

        // ── 切換到指定卡片 ──
        function activateCard(card) {
            if (activeCard === card) return;

            if (pollTimer)  { clearInterval(pollTimer); pollTimer = null; }
            if (ytPlayer)   { try { ytPlayer.destroy(); } catch (_) {} ytPlayer = null; }
            if (activeCard) { activeCard.classList.remove('active'); }

            activeCard = card;
            syncCdToCard(card);
            var ytId = card.dataset.youtubeId;

            if (window.ytApiReady) {
                createPlayer(card, ytId);
            } else {
                // API 尚未就緒，輪詢等待
                var wait = setInterval(function () {
                    if (window.ytApiReady) { clearInterval(wait); createPlayer(card, ytId); }
                }, 80);
            }
        }

        // ── 篩選狀態 ──
        var activeLang   = 'all';
        var activeArtist = 'all';

        function applyFilters() {
            document.querySelectorAll('.date-group').forEach(function (section) {
                var count = 0;
                section.querySelectorAll('.mc-card').forEach(function (card) {
                    var langOk   = activeLang   === 'all' || card.dataset.language === activeLang;
                    var artistOk = activeArtist === 'all' || card.dataset.artist   === activeArtist;
                    if (langOk && artistOk) { card.style.display = ''; count++; }
                    else                    { card.style.display = 'none'; }
                });
                section.style.display = count === 0 ? 'none' : '';
            });
        }

        // ── 語系 tab ──
        document.querySelectorAll('.lang-tab').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.lang-tab').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                activeLang = btn.dataset.lang;
                applyFilters();
            });
        });

        // ── 歌手篩選 ──
        var select = document.getElementById('artist-select');
        if (select) {
            select.addEventListener('change', function () {
                activeArtist = select.value;
                applyFilters();
            });
        }

        // ── 卡片懸停（正在播音樂時，移到其他卡片需等 3 秒才切換）──
        document.querySelectorAll('.mc-card').forEach(function (card) {
            if (!card.dataset.youtubeId) return;

            card.addEventListener('mouseenter', function () {
                clearTimeout(switchTimer);
                if (activeCard === card) return;        // 已在播這首，不動作
                if (activeCard) {
                    // 有其他歌在播：延遲 2 秒才切換（CD 封面也等到真正切換才更新）
                    switchTimer = setTimeout(function () { activateCard(card); }, 2000);
                } else {
                    // 沒有歌在播：立即開始
                    activateCard(card);
                }
            });

            card.addEventListener('mouseleave', function () {
                clearTimeout(switchTimer);  // 離開卡片就取消預約切換
            });
        });

        // ── CD 滾輪 ──
        var wheelTimer = null;
        if (cdZone) {
            cdZone.addEventListener('wheel', function(e) {
                e.preventDefault();
                if (wheelTimer) return;
                wheelTimer = setTimeout(function() { wheelTimer = null; }, 400);
                cdCycle(e.deltaY > 0 ? 1 : -1);
            }, { passive: false });
        }

        // ── CD 拖拉 / 觸控 ──
        var dragY = null, dragMoved = false;
        if (cdZone) {
            cdZone.addEventListener('mousedown', function(e) { dragY = e.clientY; dragMoved = false; e.preventDefault(); });
            window.addEventListener('mousemove', function(e) {
                if (dragY === null) return;
                var d = e.clientY - dragY;
                if (Math.abs(d) > 30 && !dragMoved) { dragMoved = true; dragY = e.clientY; cdCycle(d > 0 ? 1 : -1); }
            });
            window.addEventListener('mouseup', function() { dragY = null; });
            cdZone.addEventListener('touchstart', function(e) { dragY = e.touches[0].clientY; dragMoved = false; }, { passive: true });
            cdZone.addEventListener('touchmove', function(e) {
                if (dragY === null) return;
                var d = e.touches[0].clientY - dragY;
                if (Math.abs(d) > 30 && !dragMoved) { dragMoved = true; dragY = e.touches[0].clientY; cdCycle(d > 0 ? 1 : -1); }
            }, { passive: true });
            cdZone.addEventListener('touchend', function() { dragY = null; }, { passive: true });

            // 箭頭點擊
            var au = document.getElementById('cd-arrow-up'), ad = document.getElementById('cd-arrow-down');
            if (au) au.addEventListener('click', function() { cdCycle(-1); });
            if (ad) ad.addEventListener('click', function() { cdCycle(1); });
        }

        // ── 播放 / 暫停 ──
        mpPlayPause.addEventListener('click', function () {
            if (!ytPlayer) return;
            var state = ytPlayer.getPlayerState();
            if (state === 1) ytPlayer.pauseVideo();
            else             ytPlayer.playVideo();
        });

        // ── 關閉 ──
        mpClose.addEventListener('click', stopPlayer);

        // ── 進度條拖拉 ──
        mpBar.addEventListener('mousedown',  function () { isDragging = true; });
        mpBar.addEventListener('touchstart', function () { isDragging = true; }, { passive: true });

        mpBar.addEventListener('input', function () {
            if (!ytPlayer) return;
            var dur = ytPlayer.getDuration();
            var cur = (mpBar.value / 1000) * dur;
            mpCur.textContent = fmt(cur);
            fillBar((mpBar.value / 1000) * 100);
        });

        function commitSeek() {
            isDragging = false;
            if (!ytPlayer) return;
            var dur = ytPlayer.getDuration();
            ytPlayer.seekTo((mpBar.value / 1000) * dur, true);
        }
        mpBar.addEventListener('mouseup',  commitSeek);
        mpBar.addEventListener('touchend', commitSeek);

        // ── 初始化：同步第一張卡片到 CD ──
        if (allCards.length) syncCdToCard(allCards[0]);
    }

    document.addEventListener('astro:page-load', musicSetup);
</script>

<style>
    .music-archive {
        max-width: 1400px;
        margin: 2rem auto;
        padding: 0;
        font-family: "Noto Serif TC", serif;
    }

    /* ── Header ── */
    .header-row { display: flex; align-items: flex-end; gap: 2.5rem; }
    .archive-header h1 { font-size: 1.6rem; margin: 0; font-weight: 700; letter-spacing: -1.5px; }
    .archive-header h1 small { font-size: 0.75rem; font-family: var(--font-mono); letter-spacing: 4px; color: var(--muted); font-weight: 400; margin-left: 0.6rem; }
    .header-line { width: 100%; height: 1px; background: var(--border); margin: 1rem 0 1.5rem; position: relative; }
    .header-line::after { content: ''; position: absolute; left: 0; top: -1px; width: 80px; height: 3px; background: var(--accent); }

    .page-desc {
        flex: 1;
        font-size: 0.82rem;
        color: var(--muted);
        line-height: 1.8;
        margin: 0 0 0.15rem 0;
        font-style: italic;
        padding-left: 2rem;
        border-left: 1px solid var(--border);
        min-width: 120px;
    }

    /* ── Filter ── */
    .archive-filter { display: flex; align-items: center; gap: 1.4rem; padding-bottom: 0.15rem; flex-shrink: 0; }
    .lang-filter { display: flex; align-items: center; gap: 0.6rem; }
    .artist-filter { display: flex; align-items: center; gap: 0.6rem; }
    .filter-label { font-size: 0.6rem; font-family: var(--font-mono); letter-spacing: 2px; color: var(--muted); font-weight: 700; text-transform: uppercase; white-space: nowrap; }

    /* 語系 tabs */
    .lang-tabs { display: flex; align-items: center; gap: 0.3rem; }
    .lang-tab { background: none; border: none; cursor: pointer; font-family: "Noto Serif TC", serif; font-size: 0.78rem; color: var(--muted); padding: 0; transition: color 0.25s; letter-spacing: 0.5px; }
    .lang-tab.active { color: var(--ink); font-weight: 700; }
    .lang-tab:hover { color: var(--accent); }
    .tab-div { color: var(--border); font-size: 0.7rem; user-select: none; }

    .select-wrapper { position: relative; display: inline-flex; align-items: center; }
    .filter-select { appearance: none; -webkit-appearance: none; background: transparent; border: 1px solid var(--border); border-radius: 3px; padding: 0.3rem 1.8rem 0.3rem 0.7rem; font-size: 0.78rem; font-family: "Noto Serif TC", serif; color: var(--ink); cursor: pointer; transition: border-color 0.3s, color 0.3s; min-width: 160px; }
    .filter-select:focus { outline: none; border-color: var(--accent); }
    .filter-select:hover { border-color: var(--accent); color: var(--accent); }
    .select-arrow { position: absolute; right: 0.5rem; font-size: 0.6rem; color: var(--muted); pointer-events: none; transition: color 0.3s; }
    .select-wrapper:hover .select-arrow { color: var(--accent); }

    /* ── Two-panel layout ── */
    .two-panel-layout {
        display: flex;
        gap: 2.5rem;
        align-items: flex-start;
    }
    .cd-panel {
        width: 38%;
        flex-shrink: 0;
        position: sticky;
        top: calc(var(--nav-h, 60px) + 1.5rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.2rem;
        padding: 1.8rem 1rem 1.2rem;
        border-radius: 8px;
        background: radial-gradient(ellipse 90% 55% at 50% 38%, rgba(139,69,19,0.07) 0%, transparent 70%);
    }
    .grid-panel { flex: 1; min-width: 0; }

    /* ── CD disc ── */
    .cd-wrap { display: flex; align-items: center; justify-content: center; }
    .cd-disc {
        width: 280px;
        height: 280px;
        border-radius: 50%;
        position: relative;
